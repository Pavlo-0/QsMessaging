using System; using System.Reflection; using Azure.Messaging.ServiceBus; using Moq; using System.Threading.Tasks; var m=new Mock<ServiceBusProcessor>(); Func<ProcessMessageEventArgs,Task> h = _ => Task.CompletedTask; m.Object.ProcessMessageAsync += h; $t=m.Object.GetType(); while($t -ne $null){ Write-Host "TYPE:$($t.FullName)"; $t.GetFields([System.Reflection.BindingFlags]"Instance,NonPublic,Public,DeclaredOnly") | % { Write-Host $_.Name $_.FieldType.FullName }; $t=$t.BaseType }
